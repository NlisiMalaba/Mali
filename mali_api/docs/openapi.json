{
  "openapi": "3.0.3",
  "info": {
    "title": "Mali API",
    "version": "1.2.0",
    "description": "Production-grade API contract for Mali backend services. Endpoints are grouped by business domain and aligned with current request/response DTOs in handlers."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server"
    }
  ],
  "tags": [
    { "name": "System", "description": "Operational and service utility endpoints." },
    { "name": "Auth", "description": "User registration, authentication, refresh, and logout." },
    { "name": "Wallets", "description": "Wallet CRUD operations." },
    { "name": "Categories", "description": "Category listing and creation." },
    { "name": "Transactions", "description": "Transaction creation, listing, retrieval, and deletion." },
    { "name": "Goals", "description": "Savings goals and contributions." },
    { "name": "Budgets", "description": "Budget upsert and monthly status views." },
    { "name": "Rates", "description": "Exchange rate management and lookup." },
    { "name": "Analytics", "description": "Monthly reports, trends, and category analytics." },
    { "name": "Sync", "description": "Offline synchronization push/pull endpoints." }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string", "example": "VALIDATION_ERROR" },
              "message": { "type": "string", "example": "invalid request payload" }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "MessageEnvelope": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "operation completed successfully" }
        },
        "required": ["message"]
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "created_at"]
      },
      "AuthRegisterRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "name": { "type": "string" },
          "password": { "type": "string", "minLength": 8 }
        },
        "required": ["name", "password"]
      },
      "AuthLoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "password": { "type": "string" },
          "device_id": { "type": "string" }
        },
        "required": ["password", "device_id"]
      },
      "AuthRefreshRequest": {
        "type": "object",
        "properties": {
          "refresh_token": { "type": "string" },
          "device_id": { "type": "string" }
        },
        "required": ["device_id"]
      },
      "AuthLogoutRequest": {
        "type": "object",
        "properties": {
          "refresh_token": { "type": "string" }
        }
      },
      "AccessTokenEnvelope": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" }
        },
        "required": ["access_token"]
      },
      "AuthRegisterResponse": {
        "type": "object",
        "properties": {
          "user": { "$ref": "#/components/schemas/UserProfile" }
        },
        "required": ["user"]
      },
      "Wallet": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "wallet_type": { "type": "string" },
          "balance": { "type": "string", "example": "100.0000" },
          "running_balance": { "type": "string", "example": "100.0000" },
          "is_active": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "currency", "wallet_type", "balance", "running_balance", "is_active", "created_at"]
      },
      "CreateWalletRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "wallet_type": { "type": "string" },
          "balance": { "type": "string", "example": "0" }
        },
        "required": ["name", "currency", "wallet_type"]
      },
      "UpdateWalletRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      },
      "WalletEnvelope": {
        "type": "object",
        "properties": {
          "wallet": { "$ref": "#/components/schemas/Wallet" }
        },
        "required": ["wallet"]
      },
      "WalletListResponse": {
        "type": "object",
        "properties": {
          "wallets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Wallet" }
          }
        },
        "required": ["wallets"]
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid", "nullable": true },
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "color_hex": { "type": "string", "example": "#14B8A6" },
          "type": { "type": "string", "enum": ["income", "expense"] }
        },
        "required": ["id", "name", "icon", "color_hex", "type"]
      },
      "CreateCategoryRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "color_hex": { "type": "string" },
          "type": { "type": "string", "enum": ["income", "expense"] }
        },
        "required": ["name", "icon", "color_hex", "type"]
      },
      "CategoryEnvelope": {
        "type": "object",
        "properties": {
          "category": { "$ref": "#/components/schemas/Category" }
        },
        "required": ["category"]
      },
      "CategoryListResponse": {
        "type": "object",
        "properties": {
          "categories": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Category" }
          }
        },
        "required": ["categories"]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "wallet_id": { "type": "string", "format": "uuid" },
          "category_id": { "type": "string", "format": "uuid", "nullable": true },
          "type": { "type": "string", "enum": ["income", "expense", "transfer"] },
          "amount": { "type": "string", "example": "125.5000" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "notes": { "type": "string", "nullable": true },
          "source": { "type": "string" },
          "transacted_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "sync_id": { "type": "string", "format": "uuid", "nullable": true },
          "transfer_to_wallet_id": { "type": "string", "format": "uuid", "nullable": true },
          "exchange_rate": { "type": "string", "nullable": true }
        },
        "required": ["id", "user_id", "wallet_id", "type", "amount", "currency", "source", "transacted_at", "created_at"]
      },
      "CreateTransactionRequest": {
        "type": "object",
        "properties": {
          "wallet_id": { "type": "string", "format": "uuid" },
          "category_id": { "type": "string", "format": "uuid", "nullable": true },
          "type": { "type": "string", "enum": ["income", "expense", "transfer"] },
          "amount": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "notes": { "type": "string" },
          "source": { "type": "string" },
          "transacted_at": { "type": "string", "format": "date-time" },
          "sync_id": { "type": "string", "format": "uuid", "nullable": true },
          "transfer_to_wallet_id": { "type": "string", "format": "uuid", "nullable": true },
          "exchange_rate": { "type": "string" }
        },
        "required": ["wallet_id", "type", "amount", "currency", "source", "transacted_at"]
      },
      "TransactionEnvelope": {
        "type": "object",
        "properties": {
          "transaction": { "$ref": "#/components/schemas/Transaction" }
        },
        "required": ["transaction"]
      },
      "TransactionCursor": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "transacted_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "transacted_at"]
      },
      "TransactionListResponse": {
        "type": "object",
        "properties": {
          "transactions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Transaction" }
          },
          "next_cursor": {
            "$ref": "#/components/schemas/TransactionCursor"
          }
        },
        "required": ["transactions"]
      },
      "Goal": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "emoji": { "type": "string", "nullable": true },
          "goal_type": { "type": "string", "nullable": true },
          "target_amount": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "saved_amount": { "type": "string" },
          "required_monthly": { "type": "string" },
          "deadline": { "type": "string", "format": "date-time", "nullable": true },
          "priority": { "type": "integer" },
          "is_completed": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "user_id", "name", "target_amount", "currency", "saved_amount", "required_monthly", "priority", "is_completed", "created_at"]
      },
      "CreateGoalRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "emoji": { "type": "string" },
          "goal_type": { "type": "string" },
          "target_amount": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "saved_amount": { "type": "string" },
          "deadline": { "type": "string", "format": "date-time" },
          "priority": { "type": "integer" }
        },
        "required": ["name", "target_amount", "currency", "deadline"]
      },
      "UpdateGoalRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "emoji": { "type": "string" },
          "goal_type": { "type": "string" },
          "target_amount": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "deadline": { "type": "string", "format": "date-time" },
          "priority": { "type": "integer" },
          "is_completed": { "type": "boolean" }
        },
        "required": ["name", "target_amount", "currency", "deadline"]
      },
      "ContributeGoalRequest": {
        "type": "object",
        "properties": {
          "amount": { "type": "string" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "notes": { "type": "string" },
          "contributed_at": { "type": "string", "format": "date-time" }
        },
        "required": ["amount"]
      },
      "GoalEnvelope": {
        "type": "object",
        "properties": {
          "goal": { "$ref": "#/components/schemas/Goal" }
        },
        "required": ["goal"]
      },
      "GoalListResponse": {
        "type": "object",
        "properties": {
          "goals": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Goal" }
          }
        },
        "required": ["goals"]
      },
      "Budget": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "category_id": { "type": "string", "format": "uuid" },
          "currency": { "type": "string" },
          "amount": { "type": "string" },
          "month": { "type": "integer", "minimum": 1, "maximum": 12 },
          "year": { "type": "integer", "minimum": 1 },
          "rollover": { "type": "boolean" }
        },
        "required": ["id", "user_id", "category_id", "currency", "amount", "month", "year", "rollover"]
      },
      "UpsertBudgetRequest": {
        "type": "object",
        "properties": {
          "category_id": { "type": "string", "format": "uuid" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "amount": { "type": "string" },
          "month": { "type": "integer", "minimum": 1, "maximum": 12 },
          "year": { "type": "integer", "minimum": 1 },
          "rollover": { "type": "boolean" }
        },
        "required": ["category_id", "currency", "amount", "month", "year"]
      },
      "BudgetEnvelope": {
        "type": "object",
        "properties": {
          "budget": { "$ref": "#/components/schemas/Budget" }
        },
        "required": ["budget"]
      },
      "BudgetStatusItem": {
        "type": "object",
        "properties": {
          "budget": { "$ref": "#/components/schemas/Budget" },
          "spent": { "type": "string" },
          "remaining": { "type": "string" },
          "percent_used": { "type": "string" }
        },
        "required": ["budget", "spent", "remaining", "percent_used"]
      },
      "BudgetStatusListResponse": {
        "type": "object",
        "properties": {
          "budgets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BudgetStatusItem" }
          }
        },
        "required": ["budgets"]
      },
      "Rate": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "from_currency": { "type": "string" },
          "to_currency": { "type": "string" },
          "rate": { "type": "string" },
          "source": { "type": "string" },
          "valid_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "user_id", "from_currency", "to_currency", "rate", "source", "valid_at"]
      },
      "SetManualRateRequest": {
        "type": "object",
        "properties": {
          "from_currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "to_currency": { "type": "string", "minLength": 3, "maxLength": 3 },
          "rate": { "type": "string" },
          "valid_at": { "type": "string", "format": "date-time" }
        },
        "required": ["from_currency", "to_currency", "rate"]
      },
      "RateEnvelope": {
        "type": "object",
        "properties": {
          "rate": { "$ref": "#/components/schemas/Rate" }
        },
        "required": ["rate"]
      },
      "RateListResponse": {
        "type": "object",
        "properties": {
          "rates": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Rate" }
          }
        },
        "required": ["rates"]
      },
      "AnalyticsMonthlyReportResponse": {
        "type": "object",
        "properties": {
          "report": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": ["report"]
      },
      "AnalyticsTrendsResponse": {
        "type": "object",
        "properties": {
          "trends": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        },
        "required": ["trends"]
      },
      "AnalyticsCategoriesResponse": {
        "type": "object",
        "properties": {
          "categories": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        },
        "required": ["categories"]
      },
      "SyncChangeRequest": {
        "type": "object",
        "properties": {
          "sync_id": { "type": "string", "format": "uuid" },
          "entity": { "type": "string", "enum": ["transaction", "goal", "budget", "wallet"] },
          "operation": { "type": "string" },
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": ["sync_id", "entity", "operation", "payload"]
      },
      "SyncPushRequest": {
        "type": "object",
        "properties": {
          "changes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": { "$ref": "#/components/schemas/SyncChangeRequest" }
          }
        },
        "required": ["changes"]
      },
      "SyncConflict": {
        "type": "object",
        "properties": {
          "sync_id": { "type": "string" },
          "entity": { "type": "string" },
          "operation": { "type": "string" },
          "reason": { "type": "string" }
        },
        "required": ["sync_id", "entity", "operation", "reason"]
      },
      "SyncPushResponse": {
        "type": "object",
        "properties": {
          "accepted_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "conflicts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SyncConflict" }
          },
          "summary": {
            "type": "object",
            "properties": {
              "received": { "type": "integer" },
              "accepted": { "type": "integer" },
              "conflicts": { "type": "integer" }
            },
            "required": ["received", "accepted", "conflicts"]
          }
        },
        "required": ["accepted_ids", "conflicts", "summary"]
      },
      "SyncDelta": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "entity_type": { "type": "string" },
          "entity_id": { "type": "string", "format": "uuid" },
          "operation": { "type": "string" },
          "payload": { "type": "object", "additionalProperties": true },
          "synced_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "entity_type", "entity_id", "operation", "payload", "synced_at"]
      },
      "SyncPullResponse": {
        "type": "object",
        "properties": {
          "changes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SyncDelta" }
          },
          "next_cursor": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "synced_at": { "type": "string", "format": "date-time" }
            },
            "required": ["id", "synced_at"]
          }
        },
        "required": ["changes"]
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid authentication credentials.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "ValidationError": {
        "description": "Validation or request shape error.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "InternalError": {
        "description": "Unexpected internal server error.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      }
    },
    "parameters": {
      "UUIDPathId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Service health probe",
        "responses": {
          "200": {
            "description": "Service is healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" }
                  },
                  "required": ["status"]
                }
              }
            }
          }
        }
      }
    },
    "/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRegisterRequest" },
              "example": {
                "email": "user@example.com",
                "name": "Mali User",
                "password": "StrongPass123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registration successful.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthRegisterResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "409": { "$ref": "#/components/responses/ValidationError" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthLoginRequest" },
              "example": {
                "email": "user@example.com",
                "password": "StrongPass123",
                "device_id": "ios-iphone-15"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccessTokenEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRefreshRequest" },
              "example": {
                "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                "device_id": "ios-iphone-15"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token refreshed.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccessTokenEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/ValidationError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout current session",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthLogoutRequest" },
              "example": {
                "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout successful.",
            "content": {
              "application/json": {
